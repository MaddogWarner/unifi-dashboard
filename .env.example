UNIFI_HOST=https://192.168.1.1
UNIFI_API_KEY=your-api-key-here
UNIFI_SITE=default
UNIFI_VERIFY_SSL=false

POSTGRES_HOST=postgres
POSTGRES_DB=unifi_dashboard
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=changeme

SCANNER_BASE_URL=http://scanner:8002
SYSLOG_PORT=514
LOG_RETENTION_DAYS=30
POLL_INTERVAL_SECONDS=60

MCP_AUTH_TOKEN=change-this-long-random-token
# Set only for isolated local development. Production should require MCP_AUTH_TOKEN.
MCP_AUTH_DISABLED=false
MCP_RESOURCE_SERVER_URL=http://localhost:8001

# Dashboard auth — generate with: openssl rand -hex 32
AUTH_SECRET=change-this-long-random-secret
AUTH_TOKEN_LIFETIME_SECONDS=86400

# Frontend development only. Use http://localhost when proxying through Docker Compose nginx.
VITE_API_URL=http://localhost:8000
